{
  "id": "com.halen.autocomplete",
  "name": "Inline Autocomplete",
  "summary": "Pause, then Tab to accept a short continuation.",
  "version": "1.0.0",
  "halenApiVersion": "0.1",
  "executable": "/usr/bin/python3",
  "args": ["plugin.py"],
  "events": ["text.pause", "caret.moved", "app.focused", "hotkey.fired", "finding.detected", "finding.cleared"],
  "permissions": ["inference"],
  "icon": "text.append",
  "category": "writing"
}
