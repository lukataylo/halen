{
  "manifest_version": 3,
  "name": "Halen for Web",
  "version": "0.1.0",
  "description": "Lets Halen see typing in browser text fields so its plugins (snippets, typo-fixer, sentiment-guard) work on Slack, Discord, Gmail, Docs and everywhere else macOS Accessibility can't reach.",
  "minimum_chrome_version": "109",

  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "action": {
    "default_title": "Halen for Web",
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png"
    }
  }
}
